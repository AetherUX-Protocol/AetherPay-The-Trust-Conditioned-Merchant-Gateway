# --- AETHERPAY CONFIGURATION ---
# The base URL of your application (e.g., http://localhost:3000)
APP_URL=http://localhost:3000

# --- DODO PAYMENTS (Merchant of Record) ---
# Get your API Key from Dashboard > Developer > API Keys
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here

# Use 'test_mode' for the hackathon (Standard: 'test_mode' or 'live_mode')
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Create a product in the Dodo Dashboard and paste the ID here (starts with 'pdt_')
DODO_PRODUCT_ID=pdt_your_product_id_here

# Webhook Secret from Dashboard > Developer > Webhooks (for payment reconciliation)
DODO_PAYMENTS_WEBHOOK_SECRET=your_webhook_secret_here

# --- QVAC BY TETHER (Sovereign Intelligence) ---
# Seed for the P2P Provider service (Optional: used for distributed inference)
QVAC_HYPERSWARM_SEED=your_32_byte_hex_seed_here

# --- SOLANA SETTLEMENT ---
# (Optional) If using a specific RPC provider instead of the default public one
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
